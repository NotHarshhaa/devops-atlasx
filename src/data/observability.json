      "GET _cluster/allocation/explain",
      "GET _cat/allocation?v",
      "Check cluster.routing.allocation.disk.watermark settings"
    ],
    "fix": [
      "Raise the watermark temporarily so recovery can proceed:",
      "```json\nPUT _cluster/settings\n{\n  \"transient\": {\n    \"cluster.routing.allocation.disk.watermark.low\": \"90%\",\n    \"cluster.routing.allocation.disk.watermark.high\": \"95%\"\n  }\n}\n```",
      "Re-route the stuck shard manually if needed:",
      "```json\nPOST _cluster/reroute?retry_failed=true\n```"
    ],
    "prevention": [
      "Automate node attribute labelling via user data",
      "Track shard-to-node ratio and rebalance before maintenance",
      "Use ILM to keep shards below 50GB each"
    ],
    "tags": ["elasticsearch", "cluster", "shards", "observability"]
  },
